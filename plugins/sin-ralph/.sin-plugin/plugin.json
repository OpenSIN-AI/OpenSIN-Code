{
  "name": "sin-ralph",
  "version": "1.0.0",
  "description": "Stop-Hook-basierter iterativer Self-Referential Loop für OpenSIN-Code",
  "author": {
    "name": "OpenSIN-AI",
    "email": "developer@opensin.ai"
  },
  "license": "MIT",
  "type": "plugin",
  "commands": [
    "commands/cancel-ralph.md",
    "commands/ralph-help.md",
    "commands/ralph-loop.md"
  ],
  "hooks": {
    "Stop": "hooks/stop-hook.ts"
  },
  "config": {
    "stateFile": ".opensin/ralph-state.json",
    "defaultMaxIterations": 50,
    "completionPromiseMarker": "<promise>COMPLETE</promise>"
  }
}
