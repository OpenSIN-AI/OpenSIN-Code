{
  "name": "sin-pr-review",
  "version": "1.0.0",
  "description": "Comprehensive PR review toolkit with one orchestration command and six specialized review agents for comments, tests, failures, types, quality, and simplification.",
  "author": {
    "name": "OpenSIN-AI",
    "email": "developer@opensin.ai"
  },
  "type": "plugin",
  "commands": [
    "commands/review-pr.md"
  ],
  "agents": [
    "agents/code-reviewer.md",
    "agents/code-simplifier.md",
    "agents/comment-analyzer.md",
    "agents/pr-test-analyzer.md",
    "agents/silent-failure-hunter.md",
    "agents/type-design-analyzer.md"
  ],
  "config": {
    "parallelReviewers": true,
    "defaultConfidenceThreshold": 80,
    "supportsComprehensiveReview": true
  }
}
