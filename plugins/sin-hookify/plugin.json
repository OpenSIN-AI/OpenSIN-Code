{
  "name": "sin-hookify",
  "version": "1.0.0",
  "description": "Markdown-basierte Hook-Regel-Engine für OpenSIN-Code. Erstelle Hooks durch einfache .md Files mit YAML-Frontmatter.",
  "author": "OpenSIN-AI",
  "license": "MIT",
  "type": "plugin",
  "commands": [
    "commands/hookify.md",
    "commands/hookify-list.md",
    "commands/hookify-configure.md",
    "commands/hookify-help.md"
  ],
  "hooks": {
    "PreToolUse": "hooks/pretooluse.ts",
    "PostToolUse": "hooks/posttooluse.ts",
    "Stop": "hooks/stop.ts",
    "UserPromptSubmit": "hooks/userpromptsubmit.ts"
  },
  "skills": [],
  "agents": [],
  "mcpServers": [],
  "dependencies": {},
  "config": {
    "rulesDirectory": ".opensin/hookify",
    "ruleFilePattern": "hookify.*.local.md",
    "maxRules": 100,
    "regexCacheSize": 128
  }
}
