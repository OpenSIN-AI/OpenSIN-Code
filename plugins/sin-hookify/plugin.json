{
  "name": "sin-hookify",
  "version": "1.0.0",
  "description": "Create hook rules from explicit instructions or detected frustration patterns with helper commands, one analyzer agent, and reusable hook configuration.",
  "author": {
    "name": "OpenSIN-AI",
    "email": "developer@opensin.ai"
  },
  "type": "plugin",
  "commands": [
    "commands/configure.md",
    "commands/help.md",
    "commands/hookify.md",
    "commands/list.md"
  ],
  "agents": [
    "agents/conversation-analyzer.md"
  ],
  "hooks": "./hooks/hooks.json",
  "config": {
    "rulesDirectory": ".sin",
    "rulePrefix": "hookify",
    "supportsConversationAnalysis": true
  },
  "skills": [
    "skills/writing-rules"
  ]
}
