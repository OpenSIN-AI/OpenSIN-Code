{
  "name": "sin-feature-dev",
  "version": "1.0.0",
  "description": "Comprehensive 7-phase feature development workflow with specialized agents for codebase exploration, architecture design, and quality review",
  "author": {
    "name": "OpenSIN-AI",
    "email": "dev@opensin.ai"
  },
  "license": "MIT",
  "type": "plugin",
  "commands": [
    "commands/feature-dev.md"
  ],
  "agents": [
    "agents/code-architect.md",
    "agents/code-explorer.md",
    "agents/code-reviewer.md"
  ],
  "config": {
    "parallelAgents": true,
    "maxExplorers": 3,
    "maxArchitects": 3,
    "maxReviewers": 3,
    "phases": [
      "discovery",
      "codebase-exploration",
      "clarifying-questions",
      "architecture-design",
      "implementation",
      "quality-review",
      "summary"
    ]
  }
}
