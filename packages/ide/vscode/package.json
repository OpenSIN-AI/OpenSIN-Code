{
  "name": "@opensin/ide-vscode",
  "displayName": "OpenSIN",
  "description": "OpenSIN — Autonomous AI coding agent integration for VS Code",
  "version": "0.1.0",
  "publisher": "opensin",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opensin.chat.focus",
        "title": "Focus OpenSIN Chat",
        "category": "OpenSIN",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "opensin.chat.new",
        "title": "New OpenSIN Session",
        "category": "OpenSIN",
        "icon": "$(add)"
      },
      {
        "command": "opensin.diff.open",
        "title": "Open OpenSIN Diff",
        "category": "OpenSIN"
      },
      {
        "command": "opensin.acceptDiff",
        "title": "Accept OpenSIN Diff",
        "category": "OpenSIN",
        "icon": "$(check)"
      },
      {
        "command": "opensin.rejectDiff",
        "title": "Reject OpenSIN Diff",
        "category": "OpenSIN",
        "icon": "$(x)"
      },
      {
        "command": "opensin.server.connect",
        "title": "Connect to OpenSIN Server",
        "category": "OpenSIN"
      },
      {
        "command": "opensin.server.disconnect",
        "title": "Disconnect from OpenSIN Server",
        "category": "OpenSIN"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opensin",
          "title": "OpenSIN",
          "icon": "$(symbol-event)"
        }
      ]
    },
    "views": {
      "opensin": [
        {
          "type": "webview",
          "id": "opensin.chat",
          "name": "Chat",
          "contextualTitle": "OpenSIN Chat"
        },
        {
          "id": "opensin.sessions",
          "name": "Sessions",
          "visibility": "collapsed"
        },
        {
          "id": "opensin.activities",
          "name": "Activities",
          "visibility": "collapsed"
        }
      ]
    },
    "configuration": {
      "title": "OpenSIN",
      "properties": {
        "opensin.server.url": {
          "type": "string",
          "default": "http://localhost:4096",
          "description": "URL of the OpenSIN API server"
        },
        "opensin.server.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to the OpenSIN server on workspace open"
        },
        "opensin.chat.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Theme for the chat panel"
        },
        "opensin.diff.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open diff editor when OpenSIN produces file edits"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "opensin.chat.new",
          "when": "view == opensin.chat",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "opensin.acceptDiff",
          "when": "opensin.diffVisible",
          "group": "navigation"
        },
        {
          "command": "opensin.rejectDiff",
          "when": "opensin.diffVisible",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opensin.chat.focus",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "build": "tsc --noEmit && bun build src/extension.ts --outdir dist --target node --external vscode --external path --external fs --external os --external crypto",
    "watch": "bun build src/extension.ts --outdir dist --target node --external vscode --external path --external fs --external os --external crypto --watch",
    "package": "vsce package",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@opensin/ide-protocol": "file:../protocol",
    "ws": "^8.18.0"
  }
}
