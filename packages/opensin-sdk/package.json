{
  "name": "@opensin/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the OpenSIN A2A protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opensin": "./dist/standalone_cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./session": {
      "import": "./dist/session.js",
      "types": "./dist/session.d.ts"
    },
    "./events": {
      "import": "./dist/events.js",
      "types": "./dist/events.d.ts"
    },
    "./providers": {
      "import": "./dist/providers.js",
      "types": "./dist/providers.d.ts"
    },
    "./autonomy": {
      "import": "./dist/autonomy/index.js",
      "types": "./dist/autonomy/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "echo 'No linter configured yet' && exit 0",
    "start": "node dist/standalone_cli/index.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "opensin",
    "a2a",
    "sdk",
    "typescript",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "commander": "^12.0.0",
    "node-fetch": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "smol-toml": "^1.6.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
