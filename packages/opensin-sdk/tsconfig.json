{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": [
      "ES2021"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": [
      "node",
      "bun"
    ],
    "noEmitOnError": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__",
    "src/archived",
    "src/powerup",
    "src/standalone_cli",
    "src/skills_v2",
    "src/buddy_v2",
    "src/commands_v2",
    "src/components_v2",
    "src/cli_v2",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/i18n",
    "src/design_mode",
    "src/effort_control",
    "src/hooks",
    "src/design-mode",
    "src/file_changes_panel",
    "src/terminal_notifications",
    "src/session_naming",
    "src/skill_commands",
    "src/prompt_interrupt",
    "src/plugin_state",
    "src/subtask_tree",
    "src/supercomplete",
    "src/copy_command",
    "src/color_picker",
    "src/bridge_system",
    "src/bootstrap_system",
    "src/bare_mode",
    "src/background_agents",
    "src/assistant_orchestration",
    "src/ai_search",
    "src/agents",
    "src/design-canvas",
    "src/brand",
    "src/buddy",
    "src/cli_framework",
    "src/coordinator",
    "src/continue_work",
    "src/envsitter",
    "src/handoff",
    "src/ink_ui",
    "src/loop",
    "src/mcp_stdio",
    "src/safety_net",
    "src/session_persistence",
    "src/terminal_ui",
    "src/hooks_v2",
    "src/ink_v2",
    "src/jetbrains",
    "src/jetbrains-plugin",
    "src/keybindings_v2",
    "src/api",
    "src/cli-agent",
    "src/commands",
    "src/tools",
    "src/runtime",
    "src/mcp",
    "src/plan_act",
    "src/lint",
    "src/live_status",
    "src/lsp"
  ]
}