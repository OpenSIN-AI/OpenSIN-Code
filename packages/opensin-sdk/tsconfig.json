{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": [
      "ES2021"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": [
      "node",
      "bun"
    ],
    "noEmitOnError": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/__tests__",
    "src/archived",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/api",
    "src/assistant_orchestration",
    "src/buddy_v2",
    "src/cli_v2",
    "src/cli-agent",
    "src/commands",
    "src/commands_v2",
    "src/components_v2",
    "src/continue_work",
    "src/coordinator",
    "src/core",
    "src/design_mode",
    "src/design-canvas",
    "src/design-mode",
    "src/hooks",
    "src/hooks_v2",
    "src/i18n",
    "src/ink_v2",
    "src/jetbrains",
    "src/jetbrains-plugin",
    "src/lint",
    "src/live_status",
    "src/lsp",
    "src/mcp",
    "src/plan_act",
    "src/powerup",
    "src/runtime",
    "src/utils"
  ]
}