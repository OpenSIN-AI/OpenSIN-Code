{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "src/commands_v2",
    "src/components_v2",
    "src/hooks_v2",
    "src/ink_v2",
    "src/cli_v2",
    "src/tools_v2",
    "src/utils_v2",
    "src/agents",
    "src/assistant_orchestration",
    "src/bootstrap_system",
    "src/bridge_system",
    "src/buddy_v2",
    "src/color_picker",
    "src/context_mgmt",
    "src/coordinator",
    "src/design_mode",
    "src/effort_control",
    "src/file_changes_panel",
    "src/jetbrains",
    "src/keybindings_v2",
    "src/live_status",
    "src/named_subagents",
    "src/plugin_state",
    "src/prompt_interrupt",
    "src/skills_v2",
    "src/subtask_tree",
    "src/terminal_notifications",
    "src/vim_mode",
    "src/voice_v2",
    "src/continue_work",
    "src/hooks",
    "src/i18n",
    "src/lint",
    "src/lsp",
    "src/plan_act",
    "src/powerup",
    "src/turbo",
    "src/index.ts"
  ]
}