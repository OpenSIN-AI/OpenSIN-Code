{
  "name": "@opensin/plugin-context-pruning",
  "version": "0.1.0",
  "description": "Dynamic context pruning for token optimization in OpenSIN CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["opensin", "plugin", "context-pruning", "token-optimization"],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": { "node": ">=18.0.0" }
}
