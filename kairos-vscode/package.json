{
  "name": "kairos-vscode",
  "displayName": "OpenSIN Code",
  "description": "Agentic AI Coding Assistant — Powered by Zeus Dispatcher",
  "version": "0.2.0",
  "publisher": "opensin",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Machine Learning", "Programming Languages"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "zeus.dispatch", "title": "Dispatch Task via Zeus", "category": "Zeus" },
      { "command": "zeus.status", "title": "Show Zeus Status", "category": "Zeus" },
      { "command": "zeus.health", "title": "Run Zeus Health Check", "category": "Zeus" }
    ],
    "viewsContainers": {
      "activitybar": [{ "id": "zeus-panel", "title": "Zeus", "icon": "$(rocket)" }]
    },
    "views": {
      "zeus-panel": [
        { "id": "zeus.running", "name": "Running Tasks" },
        { "id": "zeus.failed", "name": "Failed Tasks" }
      ]
    },
    "configuration": {
      "title": "Zeus Dispatcher",
      "properties": {
        "zeus.maxParallel": { "type": "number", "default": 3 },
        "zeus.maxRetries": { "type": "number", "default": 3 },
        "zeus.healthInterval": { "type": "number", "default": 60 },
        "zeus.timeout": { "type": "number", "default": 600 }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.24.0"
  }
}
