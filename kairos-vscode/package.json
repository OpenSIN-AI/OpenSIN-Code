{
  "name": "sincode-vscode",
  "displayName": "SIN Code",
  "description": "Agentic AI Coding Assistant for OpenSIN - Powered by Kilo Code & Claude Code concepts",
  "version": "0.1.0",
  "publisher": "opensin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding-assistant",
    "sin-code",
    "sin-code",
    "agentic"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sincode.start",
        "title": "Start SIN Code",
        "category": "SIN Code"
      },
      {
        "command": "sincode.selectMode",
        "title": "Select SIN Code Mode",
        "category": "SIN Code"
      },
      {
        "command": "sincode.selectModel",
        "title": "Select SIN Code Model",
        "category": "SIN Code"
      },
      {
        "command": "sincode.addFileToContext",
        "title": "Add File to SIN Code Context",
        "category": "SIN Code"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "sincode.addFileToContext",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sincode-sidebar",
          "title": "SIN Code",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "sincode-sidebar": [
        {
          "type": "webview",
          "id": "sincode.chatView",
          "name": "SIN Code Chat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.24.0"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSIN-AI/OpenSIN-Code.git",
    "directory": "kairos-vscode"
  },
  "bugs": {
    "url": "https://github.com/OpenSIN-AI/OpenSIN-Code/issues"
  }
}
