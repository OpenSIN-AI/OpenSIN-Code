{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "small_model": "google/gemini-3-flash-preview",
  "provider": {
    "google": {
      "options": {}
    },
    "nvidia-nim": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "qwen-3.5-397b": {
          "name": "Qwen 3.5 397B (NVIDIA NIM)",
          "id": "qwen/qwen3.5-397b-a17b",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ],
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tavily/claude-mcp"
      ],
      "environment": {
        "TAVILY_API_KEY": "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"
      },
      "enabled": true
    },
    "canva": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@canva/claude-mcp"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anthropics/context7-mcp"
      ],
      "enabled": true
    },
    "skyvern": {
      "type": "local",
      "command": [
        "python3",
        "-m",
        "skyvern.mcp.server"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@anthropics/chrome-devtools-mcp"
      ],
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": true
    },
    "singularity": {
      "type": "local",
      "command": [
        "node",
        "/Users/jeremy/.singularity/CLI/bin/singularity.js",
        "mcp"
      ],
      "enabled": true
    },
    "stagehand": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browserbasehq/stagehand-mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-playwright"
      ],
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "model": "google/gemini-3.1-pro-preview",
      "steps": 999999
    },
    "plan": {
      "model": "google/gemini-3-flash-preview",
      "steps": 999999
    },
    "general": {
      "model": "google/gemini-3-flash-preview",
      "steps": 999999
    },
    "explore": {
      "model": "google/gemini-3-flash-preview",
      "steps": 999999
    }
  }
}
